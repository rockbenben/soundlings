{
  "name": "soundlings",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A 100% offline, zero-tracking sound board for kids 3–10. 89 open-licensed sounds across vehicles, animals, ambience, household, instruments, and nature.",
  "keywords": [
    "kids",
    "soundboard",
    "audio",
    "offline",
    "react",
    "ant-design",
    "vite",
    "creative-commons",
    "freesound"
  ],
  "homepage": "https://github.com/rockbenben/soundlings#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rockbenben/soundlings.git"
  },
  "bugs": {
    "url": "https://github.com/rockbenben/soundlings/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "audio:audit": "python scripts/audit_licenses.py",
    "audio:credits": "python scripts/generate_credits.py",
    "audio:health": "python scripts/audit_audio.py"
  },
  "dependencies": {
    "antd": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
